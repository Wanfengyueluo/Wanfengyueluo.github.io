  <entry>
    <title>2020-6</title>
    <link href="https://wanfengyueluo.github.io/2020/06/01/2020-6/"/>
    <id>https://wanfengyueluo.github.io/2020/06/01/2020-6/</id>
    <published>2020-06-01T08:09:07.000Z</published>
    <updated>2020-08-01T05:55:55.712Z</updated>
    
    <summary type="html">
    
      &lt;h1 id=&quot;2020-6&quot;&gt;&lt;a href=&quot;#2020-6&quot; class=&quot;headerlink&quot; title=&quot;2020.6&quot;&gt;&lt;/a&gt;2020.6&lt;/h1&gt;&lt;h2 id=&quot;6-1&quot;&gt;&lt;a href=&quot;#6-1&quot; class=&quot;headerlink&quot; title=&quot;6.1&quot;&gt;&lt;/a&gt;6.1&lt;/h2&gt;&lt;h3 id=&quot;1431-拥有最多糖果的孩子-candy-candy-candy-lollipop-lollipop&quot;&gt;&lt;a href=&quot;#1431-拥有最多糖果的孩子-candy-candy-candy-lollipop-lollipop&quot; class=&quot;headerlink&quot; title=&quot;1431.拥有最多糖果的孩子:candy::candy::candy::lollipop::lollipop:&quot;&gt;&lt;/a&gt;1431.拥有最多糖果的孩子:candy::candy::candy::lollipop::lollipop:&lt;/h3&gt;&lt;p&gt;:black_nib:解题思路：&lt;em&gt;真就是儿童节&lt;/em&gt;先找到最大值,然后遍历相加比较即可&lt;/p&gt;
&lt;pre&gt;&lt;code class=&quot;java&quot;&gt;class Solution &amp;amp;#123;
    public List&amp;lt;Boolean&amp;gt; kidsWithCandies(int[] candies, int extraCandies) &amp;amp;#123;
        List&amp;lt;Boolean&amp;gt; res = new ArrayList&amp;lt;&amp;gt;();
        if (candies.length == 0) &amp;amp;#123;
            return res;
        &amp;amp;#125;
        int max = candies[0];
        for (int candy : candies) &amp;amp;#123;
            if (max &amp;lt; candy) &amp;amp;#123;
                max = candy;
            &amp;amp;#125;
        &amp;amp;#125;
        for (int i = 0; i &amp;lt; candies.length; i++) &amp;amp;#123;
            if (max &amp;lt;= candies[i] + extraCandies) &amp;amp;#123;
                res.add(true);
            &amp;amp;#125; else &amp;amp;#123;
                res.add(false);
            &amp;amp;#125;
        &amp;amp;#125;
        return res;
    &amp;amp;#125;
&amp;amp;#125;&lt;/code&gt;&lt;/pre&gt;
    
    </summary>
    
    
    
